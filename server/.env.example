# Variables d'environnement pour le backend COVINOR
# Copiez ce fichier : cp .env.example .env

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=covinor
MYSQL_PASSWORD=votre_mot_de_passe
MYSQL_DATABASE=covinor_regleur
PORT=3001

# Clé IA Lovable (optionnel — pour l'extraction automatique des fiches)
# Sans cette clé, l'IA est simplement désactivée
LOVABLE_AI_KEY=
